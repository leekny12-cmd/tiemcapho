{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Menu item or ingredient",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Coffee", "Tea", "Food", "Ingredient"] },
        "currentStock": { "type": "number" },
        "unit": { "type": "string" },
        "minStock": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "currentStock", "unit"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["items", "totalAmount", "status", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "General income or expenditure",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "relatedObjectId": { "type": "string" }
      },
      "required": ["type", "amount", "category", "date"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Coffee shop menu and supplies"
    },
    "orders": {
      "schema": "Order",
      "description": "Sales records"
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Financial ledger"
    }
  }
}
