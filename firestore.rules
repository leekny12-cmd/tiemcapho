rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "leekny1@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0 &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1048576));
    }

    function isValidCustomer(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15;
    }

    function isValidOrder(data) {
      return data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.vat is number && data.vat >= 0 &&
             data.discount is number && data.discount >= 0 &&
             data.status in ['completed', 'pending', 'cancelled'] &&
             data.createdAt is string;
    }

    function isValidCategory(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidStockHistory(data) {
      return data.productId is string &&
             data.productName is string &&
             data.oldStock is number &&
             data.newStock is number &&
             data.change is number &&
             data.type in ['adjustment', 'manual', 'sale'] &&
             data.createdAt is string &&
             data.createdBy is string &&
             data.userEmail is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // For now, let staff update stock too
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin();
    }

    match /stock_history/{historyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidStockHistory(request.resource.data);
      allow update, delete: if false;
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
